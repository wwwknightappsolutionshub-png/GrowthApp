# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
FRONTEND_URL=https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXTAUTH_URL=https://app.yourdomain.com
NEXTAUTH_SECRET=change_me_with_openssl_rand_base64_32

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=change_me_with_openssl_rand_base64_48

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=customerflow_ai
POSTGRES_USER=customerflow
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://customerflow:change_me_strong_password@postgres:5432/customerflow_ai

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ── Cookie attributes (httpOnly access + refresh tokens) ────────────────────
# COOKIE_DOMAIN: leave blank if API and Web are on the same host. Set to
# `.yourdomain.com` if you split them across subdomains so the browser sends
# cookies on both api.yourdomain.com and app.yourdomain.com.
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── SMS (set SMS_PROVIDER=twilio to activate) ────────────────────────────────
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public base URL Twilio uses to call us (used to verify webhook signatures).
TWILIO_WEBHOOK_BASE_URL=https://api.yourdomain.com

# ── Email (set EMAIL_PROVIDER=resend to activate) ────────────────────────────
EMAIL_PROVIDER=mock
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Resend webhook signing secret (starts with whsec_). Required for /webhooks/resend.
RESEND_WEBHOOK_SECRET=

# ── Payments (set PAYMENT_PROVIDER=stripe to activate) ───────────────────────
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── AI (set AI_PROVIDER=openai to activate) ──────────────────────────────────
AI_PROVIDER=mock
OPENAI_API_KEY=

# ── Social (set SOCIAL_PROVIDER=facebook to activate) ────────────────────────
SOCIAL_PROVIDER=mock
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Google Business Profile (OAuth) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://customerflowai.online/api/v1/integrations/google/callback
INTEGRATIONS_TOKEN_ENCRYPTION_KEY=

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Backup ───────────────────────────────────────────────────────────────────
# Local retention (number of backups to keep)
BACKUP_RETAIN_DAILY=7
BACKUP_RETAIN_WEEKLY=4
BACKUP_RETAIN_MONTHLY=3
# S3 upload (leave blank for local-only backups)
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=customerflow/postgres
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=eu-west-2
# Slack/Discord webhook for backup failure alerts (optional)
BACKUP_ALERT_WEBHOOK=
