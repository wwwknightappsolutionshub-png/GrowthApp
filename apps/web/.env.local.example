# Use empty NEXT_PUBLIC_API_URL so the browser calls /api/v1/* on the Next origin;
# next.config.js rewrites those to FastAPI (see API_PROXY_TARGET).
NEXT_PUBLIC_API_URL=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_local

# Where Next.js proxies /api/v1/* and /healthz. Default in next.config.js is
# http://localhost:8000 — set to http://localhost:8002 if you use scripts/preview.ps1 defaults.
API_PROXY_TARGET=http://localhost:8000

# Server-side fetch for public pages (booking widget SSR). On VPS set to http://127.0.0.1:8000
INTERNAL_API_URL=http://127.0.0.1:8000
